      "mdast-util-to-hast": ">=13.2.1",
      "pbkdf2": ">=3.1.3",
      "sha.js": ">=2.4.12",
      "bn.js@^4": "^4.12.3",
      "bn.js@^5": "^5.2.3",
      "dompurify@^3": "^3.4.11",
      "brace-expansion@^2": "^2.0.3",
      "yaml@^2": "^2.8.3",
      "postcss": "^8.5.10",
