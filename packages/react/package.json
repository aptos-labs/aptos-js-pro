{
  "name": "@aptos-labs/react",
  "version": "1.0.0",
  "description": "React library for Aptos applications.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aptos-labs/aptos-js-pro.git",
    "directory": "packages/react"
  },
  "homepage": "https://js-pro.aptos.dev/",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./connectors": {
      "types": "./dist/connectors.d.ts",
      "default": "./dist/connectors.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "lint": "eslint --cache ./src",
    "lint:fix": "eslint --cache ./src --fix",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "@aptos-labs/js-pro": "workspace:*",
    "@aptos-labs/ts-sdk": ">=6.0.0",
    "@aptos-labs/wallet-adapter-react": ">=4.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "typescript": ">=5.0.4"
  },
  "peerDependenciesMeta": {
    "@aptos-labs/wallet-adapter-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aptos-labs/eslint-config-petra": "workspace:*",
    "@aptos-labs/js-pro": "workspace:*",
    "@aptos-labs/ts-sdk": "^7.1.3",
    "@aptos-labs/wallet-adapter-react": "^8.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.9",
    "dotenv": "^16.6.1",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "aptos",
    "apt",
    "web3",
    "blockchain",
    "dapps",
    "wallet"
  ]
}
